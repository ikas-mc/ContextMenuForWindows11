<UserControl
    x:Class="ContextMenuCustomApp.View.Menu.MenuEditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:ContextMenuCustomApp.View.Common"
    xmlns:controls="using:ContextMenuCustomApp.View.Controls"
    xmlns:converter="using:ContextMenuCustomApp.View.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ContextMenuCustomApp.View.Menu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:menu="using:ContextMenuCustomApp.Service.Menu"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converter:VisibilityConverter x:Key="VisibilityConverter" />
        <converter:EqualsVisibilityConverter x:Key="EqualsVisibilityConverter" />
        <local:WindowFlagConverter x:Key="WindowFlagConverter" />
        <DataTemplate
            x:Key="EnumComboxItem"
            x:DataType="menu:EnumItem">
            <TextBlock Text="{x:Bind Label, Mode=OneWay}" />
        </DataTemplate>
    </UserControl.Resources>
    <ScrollViewer
        Grid.Row="1"
        Grid.Column="2"
        Margin="0"
        Padding="4,4,16,4">
        <StackPanel
            Padding="0"
            Orientation="Vertical">
            <TextBlock
                Margin="0,0,0,8"
                Text="{x:Bind _appLang.MenuConfigGroup, Mode=OneWay}" />

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuTitle, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xF683;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.ActionContent>
                    <TextBox
                        PlaceholderText="open with notepad"
                        Text="{x:Bind MenuItem.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </controls:SettingItem.ActionContent>
            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuOrder, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xE8CB;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.ActionContent>
                    <muxc:NumberBox
                        LargeChange="10"
                        Maximum="999999"
                        Minimum="-999999"
                        PlaceholderText="0"
                        SmallChange="1"
                        SpinButtonPlacementMode="Inline"
                        Value="{x:Bind MenuItem.Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </controls:SettingItem.ActionContent>
            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuExe, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xECAA;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.ActionContent>
                    <TextBox
                        PlaceholderText="&quot;C:\Windows\notepad.exe&quot;"
                        Text="{x:Bind MenuItem.Exe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </controls:SettingItem.ActionContent>

                <controls:SettingItem.RightContent>
                    <Button
                        x:Name="OpenExeButton"
                        Width="56"
                        Margin="8,0,0,-1"
                        Click="OpenExeButton_OnClick"
                        ToolTipService.ToolTip="{x:Bind _appLang.MenuExeOpenTips, Mode=OneWay}">
                        <SymbolIcon Symbol="OpenFile" />
                    </Button>
                </controls:SettingItem.RightContent>
            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuParam, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xEA86;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.ActionContent>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBox
                            Grid.Row="0"
                            PlaceholderText="{x:Bind _appLang.MenuParamTips, Mode=OneWay}"
                            Text="{x:Bind MenuItem.Param, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Grid.Row="1"
                            FontStyle="Italic"
                            IsTextSelectionEnabled="True">
                            {path} {name} {nameNoExt} {parent} {extension}
                        </TextBlock>
                    </Grid>
                </controls:SettingItem.ActionContent>

            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuIcon, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xE8B9;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.ActionContent>
                    <StackPanel>
                        <TextBox
                            Margin="0,0,0,8"
                            PlaceholderText="{x:Bind _appLang.MenuIconLightInputTip, Mode=OneWay}"
                            Text="{x:Bind MenuItem.Icon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            ToolTipService.ToolTip="{x:Bind _appLang.MenuIconLightInputTip}" />
                        <TextBox
                            Margin="0,0,0,8"
                            PlaceholderText="{x:Bind _appLang.MenuIconDarkInputTip, Mode=OneWay}"
                            Text="{x:Bind MenuItem.IconDark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            ToolTipService.ToolTip="{x:Bind _appLang.MenuIconDarkInputTip, Mode=OneWay}" />
                    </StackPanel>
                </controls:SettingItem.ActionContent>
                <controls:SettingItem.RightContent>
                    <StackPanel>
                        <Button
                            Width="56"
                            Margin="8,1,0,8"
                            Click="OpenIconButton_OnClick"
                            Tag="Light"
                            ToolTipService.ToolTip="{x:Bind _appLang.MenuIconOpenTip, Mode=OneWay}">
                            <SymbolIcon Symbol="OpenFile" />
                        </Button>
                        <Button
                            Width="56"
                            Margin="8,-1,0,8"
                            Click="OpenIconButton_OnClick"
                            Tag="Dark"
                            ToolTipService.ToolTip="{x:Bind _appLang.MenuIconOpenTip, Mode=OneWay}">
                            <SymbolIcon Symbol="OpenFile" />
                        </Button>
                    </StackPanel>

                </controls:SettingItem.RightContent>
            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuMatchFolder, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xF89A;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.RightContent>
                    <local:DirectoryMatchCheckbox Value="{x:Bind MenuItem.AcceptDirectoryFlag, Mode=TwoWay}" />
                </controls:SettingItem.RightContent>
            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuMatchFile, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xF16C;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.RightContent>
                    <ComboBox
                        MinWidth="160"
                        HorizontalAlignment="Stretch"
                        ItemTemplate="{StaticResource EnumComboxItem}"
                        ItemsSource="{x:Bind FileMatchEnumItems, Mode=OneWay}"
                        SelectedIndex="{x:Bind MenuItem.AcceptFileFlag, Mode=TwoWay}" />
                </controls:SettingItem.RightContent>
                <controls:SettingItem.BottomContent>
                    <RelativePanel HorizontalAlignment="Stretch">
                        <TextBox
                            x:Name="FileAcceptExtsInput"
                            Header="{x:Bind _appLang.MenuMatchFileInputExtentionLikeTips, Mode=OneWay}"
                            PlaceholderText=".txt .zip  or *"
                            RelativePanel.AlignLeftWithPanel="True"
                            RelativePanel.AlignRightWithPanel="True"
                            Text="{x:Bind MenuItem.AcceptExts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{x:Bind MenuItem.AcceptFileFlag, Mode=OneWay, Converter={StaticResource EqualsVisibilityConverter}, ConverterParameter=1}" />

                        <TextBox
                            x:Name="FileAcceptExtsInput2"
                            Header="{x:Bind _appLang.MenuMatchFileInputExtentionTips, Mode=OneWay}"
                            PlaceholderText=".txt|.zip"
                            RelativePanel.AlignLeftWithPanel="True"
                            RelativePanel.AlignRightWithPanel="True"
                            Text="{x:Bind MenuItem.AcceptExts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{x:Bind MenuItem.AcceptFileFlag, Mode=OneWay, Converter={StaticResource EqualsVisibilityConverter}, ConverterParameter=3}" />

                        <HyperlinkButton
                            Margin="0,8,0,0"
                            Content="{x:Bind _appLang.MenuMatchFileInputExtentionWiki, Mode=OneWay}"
                            NavigateUri="https://github.com/ikas-mc/ContextMenuForWindows11/wiki/File%E2%80%90Extensions"
                            RelativePanel.AlignRightWithPanel="True"
                            RelativePanel.Below="FileAcceptExtsInput"
                            Visibility="{x:Bind MenuItem.AcceptFileFlag, Mode=OneWay, Converter={StaticResource EqualsVisibilityConverter}, ConverterParameter=1}" />

                        <HyperlinkButton
                            Margin="0,8,0,0"
                            Content="{x:Bind _appLang.MenuMatchFileInputExtentionWiki, Mode=OneWay}"
                            NavigateUri="https://github.com/ikas-mc/ContextMenuForWindows11/wiki/File%E2%80%90Extensions"
                            RelativePanel.AlignRightWithPanel="True"
                            RelativePanel.Below="FileAcceptExtsInput2"
                            Visibility="{x:Bind MenuItem.AcceptFileFlag, Mode=OneWay, Converter={StaticResource EqualsVisibilityConverter}, ConverterParameter=3}" />


                        <TextBox
                            Header="{x:Bind _appLang.MenuMatchFileInputNameRegexTips, Mode=OneWay}"
                            PlaceholderText="+?\.txt"
                            RelativePanel.AlignLeftWithPanel="True"
                            RelativePanel.AlignRightWithPanel="True"
                            Text="{x:Bind MenuItem.AcceptFileRegex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{x:Bind MenuItem.AcceptFileFlag, Mode=OneWay, Converter={StaticResource EqualsVisibilityConverter}, ConverterParameter=2}" />

                    </RelativePanel>

                </controls:SettingItem.BottomContent>

            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuMatchFiles}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xE9D5;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.Description>
                    <HyperlinkButton
                        Padding="0"
                        NavigateUri="https://github.com/ikas-mc/ContextMenuForWindows11/wiki/Help#multiple-files"
                        RelativePanel.AlignRightWithPanel="True">
                        <TextBlock Text="{x:Bind _appLang.MenuMatchFilesTips, Mode=OneWay}" />
                    </HyperlinkButton>
                </controls:SettingItem.Description>
                <controls:SettingItem.RightContent>
                    <ComboBox
                        MinWidth="160"
                        HorizontalAlignment="Stretch"
                        ItemTemplate="{StaticResource EnumComboxItem}"
                        ItemsSource="{x:Bind FilesMatchFlagEnumItems, Mode=OneWay}"
                        SelectedIndex="{x:Bind MenuItem.AcceptMultipleFilesFlag, Mode=TwoWay}" />
                </controls:SettingItem.RightContent>

                <controls:SettingItem.BottomContent>


                    <Grid Visibility="{x:Bind MenuItem.AcceptMultipleFilesFlag, Mode=OneWay, Converter={StaticResource EqualsVisibilityConverter}, ConverterParameter=2}">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBox
                            Grid.Row="0"
                            Header="{x:Bind _appLang.MenuMatchFilesJoinDelimiterTip}"
                            PlaceholderText="|"
                            Text="{x:Bind MenuItem.PathDelimiter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Header="{x:Bind _appLang.MenuMatchFilesJoinParamTip, Mode=OneWay}"
                            PlaceholderText="{}{path}"
                            Text="{x:Bind MenuItem.ParamForMultipleFiles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{x:Bind MenuItem.AcceptMultipleFilesFlag, Mode=OneWay, Converter={StaticResource EqualsVisibilityConverter}, ConverterParameter=2}" />

                        <TextBlock
                            Grid.Row="2"
                            FontStyle="Italic"
                            IsTextSelectionEnabled="True">
                            {path} {parent} {path0} {name0} {nameNoExt0} {extension0}
                        </TextBlock>
                    </Grid>

                </controls:SettingItem.BottomContent>
            </controls:SettingItem>

            <TextBlock
                Margin="0,8,0,8"
                Text="{x:Bind _appLang.MenuConfigAdvancedGroup, Mode=OneWay}" />

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuShowWindowFlag, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xF5ED;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.RightContent>
                    <ComboBox
                        MinWidth="160"
                        HorizontalAlignment="Stretch"
                        ItemTemplate="{StaticResource EnumComboxItem}"
                        ItemsSource="{x:Bind ShowWindowFlagEnumItems, Mode=OneWay}"
                        SelectedIndex="{x:Bind MenuItem.ShowWindowFlag, Mode=TwoWay, Converter={StaticResource WindowFlagConverter}}"
                        ToolTipService.ToolTip="{x:Bind _appLang.MenuShowWindowFlagTips, Mode=OneWay}" />
                </controls:SettingItem.RightContent>
            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuRunAsFlag, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xE748;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.RightContent>
                    <ComboBox
                        MinWidth="160"
                        HorizontalAlignment="Stretch"
                        ItemTemplate="{StaticResource EnumComboxItem}"
                        ItemsSource="{x:Bind RunAsFlagEnumItems, Mode=OneWay}"
                        SelectedIndex="{x:Bind MenuItem.RunAsFlag, Mode=TwoWay}"
                        ToolTipService.ToolTip="{x:Bind _appLang.MenuRunAsFlagTips, Mode=OneWay}" />
                </controls:SettingItem.RightContent>
            </controls:SettingItem>

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuWorkingDirectory, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xED25;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.ActionContent>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBox
                            PlaceholderText="{x:Bind _appLang.MenuWorkingDirectoryTips, Mode=OneWay}"
                            Text="{x:Bind MenuItem.WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Grid.Row="1"
                            FontStyle="Italic"
                            IsTextSelectionEnabled="True">
                            {parent} {path0}
                        </TextBlock>
                    </Grid>
                </controls:SettingItem.ActionContent>
            </controls:SettingItem>

            <TextBlock
                Margin="0,8,0,8"
                Text="{x:Bind _appLang.MenuFileGroup, Mode=OneWay}" />

            <controls:SettingItem
                Margin="0,0,0,8"
                Header="{x:Bind _appLang.MenuFileFileName, Mode=OneWay}">
                <controls:SettingItem.Icon>
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        Glyph="&#xE8AC;" />
                </controls:SettingItem.Icon>
                <controls:SettingItem.ActionContent>
                    <TextBlock
                        IsTextSelectionEnabled="True"
                        Text="{x:Bind MenuItem.FileName, Mode=OneWay}"
                        ToolTipService.ToolTip="{x:Bind _appLang.MenuFileFileNameTip, Mode=OneWay}" />
                </controls:SettingItem.ActionContent>
            </controls:SettingItem>

        </StackPanel>
    </ScrollViewer>

</UserControl>
